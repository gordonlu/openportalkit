{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=openportalkit;Username=openportalkit;Password=openportalkit_dev",
    "Redis": "localhost:6379"
  },
  "OpenPortalKit": {
    "Storage": {
      "Provider": "PostgreSQL",
      "PrimaryConnectionStringName": "Default",
      "CacheConnectionStringName": "Redis"
    },
    "Dashboard": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "AnalyticsPrivacy": {
      "AnonymizeIpAddresses": true,
      "RetentionDays": 180,
      "AllowCrossSiteTracking": false,
      "AllowThirdPartyCookies": false
    },
    "AgentAccess": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      },
      "BotPolicy": {
        "AllowSearchBots": true,
        "AllowTrainingBots": false,
        "AllowedUserAgents": [
          "OpenPortalKit-Smoke"
        ],
        "CrawlDelaySeconds": 2
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
