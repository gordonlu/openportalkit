{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenPortalKit": {
    "Dashboard": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "AnalyticsPrivacy": {
      "AnonymizeIpAddresses": true,
      "RetentionDays": 180,
      "AllowCrossSiteTracking": false,
      "AllowThirdPartyCookies": false
    }
  },
  "AllowedHosts": "*"
}
