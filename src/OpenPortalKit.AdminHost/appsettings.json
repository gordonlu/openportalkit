{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenPortalKit": {
    "Production": {
      "EnableHttpsRedirection": true,
      "EnableHsts": true,
      "EnableRateLimiting": true,
      "AdminRequestsPerMinute": 120,
      "PublicRequestsPerMinute": 300,
      "QueueLimit": 20,
      "LoginAttemptsPerFiveMinutes": 10,
      "HstsMaxAgeDays": 180
    },
    "AdminAuthentication": {
      "RequireAuthentication": true,
      "Mode": "Local",
      "UserName": "administrator",
      "DisplayName": "Portal Administrator",
      "PasswordHash": "",
      "IdleTimeoutMinutes": 30,
      "AbsoluteTimeoutHours": 12,
      "SessionVersion": "1",
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15,
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-oidc",
      "RequiredRole": "OpenPortalKit.Administrator",
      "DataProtectionKeyPath": "",
      "KeyEncryptionCertificatePath": "",
      "KeyEncryptionCertificatePassword": ""
    },
    "IndustryPacks": {
      "RootPath": "../../industry-packs",
      "CoreVersion": "0.1.0"
    },
    "Persistence": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "Dashboard": {
      "SnapshotTtlSeconds": 60,
      "MaxSnapshotTtlSeconds": 300,
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "AnalyticsPrivacy": {
      "AnonymizeIpAddresses": true,
      "RetentionDays": 180,
      "AllowCrossSiteTracking": false,
      "AllowThirdPartyCookies": false
    },
    "AgentAccess": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      },
      "OutputGeneration": {
        "PublicBaseUrl": "http://localhost:5051",
        "SiteId": null,
        "AuthorDisplayName": "OpenPortalKit Editorial"
      },
      "BotPolicy": {
        "AllowSearchBots": true,
        "AllowTrainingBots": false,
        "AllowedUserAgents": [],
        "CrawlDelaySeconds": null
      }
    }
  },
  "AllowedHosts": "*"
}
