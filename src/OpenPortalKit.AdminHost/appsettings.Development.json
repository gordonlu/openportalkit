{
  "DetailedErrors": true,
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=openportalkit;Username=openportalkit;Password=openportalkit_dev",
    "Redis": "localhost:6379"
  },
  "OpenPortalKit": {
    "Production": {
      "EnableHttpsRedirection": false
    },
    "AdminAuthentication": {
      "RequireAuthentication": false
    },
    "Persistence": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "Storage": {
      "Provider": "PostgreSQL",
      "PrimaryConnectionStringName": "Default",
      "CacheConnectionStringName": "Redis"
    },
    "Dashboard": {
      "SnapshotTtlSeconds": 30,
      "MaxSnapshotTtlSeconds": 120,
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "AnalyticsPrivacy": {
      "AnonymizeIpAddresses": true,
      "RetentionDays": 30,
      "AllowCrossSiteTracking": false,
      "AllowThirdPartyCookies": false
    },
    "AgentAccess": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      },
      "OutputGeneration": {
        "PublicBaseUrl": "http://localhost:5051",
        "SiteId": null,
        "AuthorDisplayName": "OpenPortalKit Editorial"
      },
      "BotPolicy": {
        "AllowSearchBots": true,
        "AllowTrainingBots": false,
        "AllowedUserAgents": [
          "OpenPortalKit-Smoke"
        ],
        "CrawlDelaySeconds": 2
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
