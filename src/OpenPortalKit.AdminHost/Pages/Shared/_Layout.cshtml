<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OpenPortalKit.AdminHost</title>
    <script type="importmap" nonce="@OpenPortalKit.Infrastructure.Production.CspNonceAccessor.Get(Context)"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OpenPortalKit.AdminHost.styles.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <form class="opk-session-control" method="post" asp-page="/Account/Logout">
            <span>@User.Identity.Name</span>
            <button type="submit">Sign out</button>
        </form>
    }
    <main role="main">
        @RenderBody()
    </main>

    <script nonce="@OpenPortalKit.Infrastructure.Production.CspNonceAccessor.Get(Context)" src="~/lib/jquery/dist/jquery.min.js"></script>
    <script nonce="@OpenPortalKit.Infrastructure.Production.CspNonceAccessor.Get(Context)" src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script nonce="@OpenPortalKit.Infrastructure.Production.CspNonceAccessor.Get(Context)" src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
