@page
@model OpenPortalKit.AdminHost.Pages.Templates.EditModel
@{
    ViewData["Title"] = "Edit Block Template";
}

<section class="opk-admin-shell">
    <partial name="_AdminSidebar" />

    <div class="opk-workspace">
        <header class="opk-topbar">
            <div><a class="opk-back-link" asp-page="/Templates/Index">Templates</a><h1>@Model.Editor.Name</h1><p>@Model.Editor.Code · versioned block configuration</p></div>
        </header>

        @if (!ViewContext.ModelState.IsValid)
        {
            <div class="opk-alert-strip"><div class="opk-alert-link is-critical">@string.Join(" ", ViewContext.ModelState.Values.SelectMany(value => value.Errors).Select(error => error.ErrorMessage))</div></div>
        }

        <form method="post" class="opk-template-editor">
            <input asp-for="Editor.Code" type="hidden" />
            <section class="opk-template-editor-main">
                <div class="opk-panel opk-template-metadata">
                    <div class="opk-panel-header"><div><h2>Template Details</h2><p>Changes create a new immutable template version.</p></div><div class="opk-editor-actions"><button class="opk-button opk-button-secondary" asp-page-handler="Preview" type="submit">Preview</button><button class="opk-button opk-button-primary" asp-page-handler="Save" type="submit">Save version</button></div></div>
                    <div class="opk-editor-fields"><label>Name<input asp-for="Editor.Name" /></label><label>Status<select asp-for="Editor.Status" asp-items="Html.GetEnumSelectList<OpenPortalKit.Modules.Content.BlockTemplates.PageTemplateStatus>()"></select></label><label class="is-wide">Description<textarea asp-for="Editor.Description" rows="2"></textarea></label></div>
                </div>

                <div class="opk-editor-block-list">
                @for (var index = 0; index < Model.Editor.Blocks.Count; index++)
                {
                    var block = Model.Editor.Blocks[index];
                    var definition = Model.Definitions.FirstOrDefault(item => item.Code == block.DefinitionCode);
                    <article class="opk-panel opk-block-editor">
                        <input asp-for="Editor.Blocks[index].Id" type="hidden" />
                        <input asp-for="Editor.Blocks[index].DefinitionCode" type="hidden" />
                        <input asp-for="Editor.Blocks[index].SchemaVersion" type="hidden" />
                        <header><div><span class="opk-block-order">@(index + 1)</span><div><h3>@(definition?.DisplayName ?? block.DefinitionCode)</h3><p>@block.SchemaVersion · @(definition?.Description)</p></div></div><label class="opk-remove-block"><input asp-for="Editor.Blocks[index].Remove" />Remove</label></header>
                        <div class="opk-block-editor-fields"><label>Order<input asp-for="Editor.Blocks[index].SortOrder" type="number" min="0" /></label><label class="is-wide">Configuration JSON<textarea asp-for="Editor.Blocks[index].ConfigurationJson" rows="5" spellcheck="false"></textarea></label></div>
                        @if (definition is not null)
                        {
                            <div class="opk-schema-fields">@foreach (var setting in definition.Settings){<span><strong>@setting.Label</strong> · @setting.Type @(setting.IsRequired ? "· required" : "")</span>}</div>
                        }
                    </article>
                }
                </div>

                <div class="opk-panel opk-add-block">
                    <label>Add predefined block<select asp-for="NewBlockCode"><option value="">Select block</option>@foreach (var definition in Model.Definitions){<option value="@definition.Code">@definition.DisplayName</option>}</select></label>
                    <button class="opk-button opk-button-secondary" asp-page-handler="AddBlock" type="submit">Add block</button>
                </div>
            </section>

            <aside class="opk-template-editor-side">
                <section class="opk-panel opk-preview-panel">
                    <div class="opk-panel-header"><div><h2>Server Preview</h2><p>Uses the same encoded renderer as the public route.</p></div></div>
                    @if (Model.PreviewHtml is not null)
                    {
                        <div class="opk-preview-surface">@Html.Raw(Model.PreviewHtml)</div>
                    }
                    else if (Model.PreviewError is not null)
                    {
                        <p class="opk-preview-error">@Model.PreviewError</p>
                    }
                    else
                    {
                        <p class="opk-preview-empty">Preview the current unsaved configuration here.</p>
                    }
                </section>
                <section class="opk-panel opk-version-list">
                    <div class="opk-panel-header"><div><h2>Version History</h2><p>Immutable template snapshots.</p></div></div>
                    <ol>@foreach (var version in Model.Versions){<li><strong>v@(version.Version)</strong><span>@version.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span><small>@version.Snapshot.Blocks.Count blocks · @version.Snapshot.Status</small></li>}</ol>
                </section>
            </aside>
        </form>
    </div>
</section>
