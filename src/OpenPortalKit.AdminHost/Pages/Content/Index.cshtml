@page
@model OpenPortalKit.AdminHost.Pages.Content.IndexModel
@using OpenPortalKit.Modules.Content.ContentItems
@{
    ViewData["Title"] = "Content Studio";
    string StatusClass(ContentPublicationStatus status) => status switch
    {
        ContentPublicationStatus.Review => "is-review",
        ContentPublicationStatus.Approved or ContentPublicationStatus.Published => "is-approved",
        ContentPublicationStatus.Rejected => "is-critical",
        ContentPublicationStatus.Draft or ContentPublicationStatus.Archived => "is-draft",
        _ => "is-draft"
    };
}

<section class="opk-admin-shell">
    <partial name="_AdminSidebar" />

    <div class="opk-workspace">
        <header class="opk-topbar">
            <div>
                <h1>Content Studio</h1>
                <p>Drafts, review state, public outputs, source traceability, and publication status.</p>
            </div>
            <div class="opk-content-count" aria-live="polite"><strong>@Model.TotalCount</strong><span>matching items</span></div>
        </header>

        @if (!ViewContext.ModelState.IsValid)
        {
            <div class="opk-alert-strip"><div class="opk-alert-link is-critical">@string.Join(" ", ViewContext.ModelState.Values.SelectMany(value => value.Errors).Select(error => error.ErrorMessage))</div></div>
        }

        <section class="opk-workbench">
            <div class="opk-content-main">
                <div class="opk-panel">
                    <form class="opk-toolbar opk-content-filters" method="get" aria-label="Content filters">
                        <label>
                            <span>Search</span>
                            <input asp-for="Search" name="q" type="search" maxlength="200" placeholder="Title, slug, or summary" />
                        </label>
                        <label>
                            <span>Status</span>
                            <select asp-for="Status">
                                <option value="">All statuses</option>
                                @foreach (var status in Enum.GetValues<ContentPublicationStatus>())
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </label>
                        <button class="opk-button opk-button-primary" type="submit">Apply filters</button>
                        <a class="opk-button opk-button-secondary" asp-page="/Content/Index">Clear</a>
                    </form>

                    <div class="opk-table-wrap">
                        <table class="opk-table opk-content-table">
                            <thead><tr><th>Title</th><th>Status</th><th>Source</th><th>Author</th><th>Updated</th></tr></thead>
                            <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="@(item.Id == Model.SelectedItem?.Id ? "is-selected" : null)">
                                    <td><strong><a class="opk-content-title" href="@Model.BuildPageUrl(Model.PageNumber, item.Id)">@item.Title</a></strong><span>/content/@item.Slug</span></td>
                                    <td><span class="opk-chip @StatusClass(item.Status)">@item.Status</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Source) ? "Direct authoring" : item.Source)</td>
                                    <td><code>@OpenPortalKit.AdminHost.Pages.Content.IndexModel.AuthorLabel(item)</code></td>
                                    <td><time datetime="@item.UpdatedAt.ToString("O")">@item.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</time></td>
                                </tr>
                            }
                            @if (Model.Items.Count == 0)
                            {
                                <tr><td class="opk-empty-cell" colspan="5">No content matches the current filters.</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="opk-pagination" aria-label="Content pages">
                            <a class="opk-button opk-button-secondary @(Model.PageNumber == 1 ? "is-disabled" : null)" href="@(Model.PageNumber == 1 ? null : Model.BuildPageUrl(Model.PageNumber - 1))" aria-disabled="@(Model.PageNumber == 1 ? "true" : null)">Previous</a>
                            <span>Page @Model.PageNumber of @Model.TotalPages</span>
                            <a class="opk-button opk-button-secondary @(Model.PageNumber == Model.TotalPages ? "is-disabled" : null)" href="@(Model.PageNumber == Model.TotalPages ? null : Model.BuildPageUrl(Model.PageNumber + 1))" aria-disabled="@(Model.PageNumber == Model.TotalPages ? "true" : null)">Next</a>
                        </nav>
                    }
                </div>
            </div>

            <aside class="opk-inspector" aria-label="Selected content details">
                <div class="opk-panel">
                @if (Model.SelectedItem is { } selected)
                {
                    <div class="opk-inspector-title">
                        <span class="opk-chip @StatusClass(selected.Status)">@selected.Status</span>
                        <h2>@selected.Title</h2>
                        <p>/content/@selected.Slug</p>
                    </div>
                    <div class="opk-inspector-section">
                        <h3>Output readiness</h3>
                        <ul class="opk-check-list">
                            <li><span class="opk-status-dot @(string.IsNullOrWhiteSpace(selected.Title) ? "is-warn" : "is-ok")"></span>Title</li>
                            <li><span class="opk-status-dot @(string.IsNullOrWhiteSpace(selected.Slug) ? "is-warn" : "is-ok")"></span>Canonical slug</li>
                            <li><span class="opk-status-dot @(string.IsNullOrWhiteSpace(selected.Summary) ? "is-warn" : "is-ok")"></span>Summary</li>
                            <li><span class="opk-status-dot @(selected.Status == ContentPublicationStatus.Published ? "is-ok" : "is-warn")"></span>HTML, Markdown, and JSON publication</li>
                            <li><span class="opk-status-dot @(selected.Status == ContentPublicationStatus.Published ? "is-ok" : "is-warn")"></span>Search and AgentSEO discovery</li>
                        </ul>
                    </div>
                    <div class="opk-inspector-section">
                        <h3>Traceability</h3>
                        <div class="opk-key-value">
                            <span>Source</span><strong>@(selected.Source ?? "Direct authoring")</strong>
                            <span>Created</span><strong>@selected.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
                            <span>Updated</span><strong>@selected.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
                            <span>Published</span><strong>@(selected.PublishedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Not published")</strong>
                            <span>Tags</span><strong>@(selected.Tags.Count == 0 ? "None" : string.Join(", ", selected.Tags))</strong>
                        </div>
                    </div>
                    <div class="opk-inspector-section">
                        <h3>Version history</h3>
                        @if (Model.Versions.Count == 0)
                        {
                            <p class="opk-muted">No persisted revisions are available.</p>
                        }
                        else
                        {
                            <div class="opk-version-list"><ol>
                            @foreach (var version in Model.Versions.Take(5))
                            {
                                <li>
                                    <strong>Revision @version.Revision</strong>
                                    <span>@version.Snapshot.Status · @version.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                    <small>Actor <code>@version.CreatedBy.ToString("N")[..8]</code></small>
                                </li>
                            }
                            </ol></div>
                        }
                    </div>
                }
                else
                {
                    <div class="opk-empty-state"><strong>No content selected</strong><span>Adjust the filters to view matching content.</span></div>
                }
                </div>
            </aside>
        </section>
    </div>
</section>
