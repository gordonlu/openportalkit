@page
@model IndexModel
@{
    ViewData["Title"] = "OpenPortalKit Admin";
}

<section class="opk-admin-shell">
    <aside class="opk-sidebar" aria-label="Admin navigation">
        <a class="opk-brand" asp-page="/Index" aria-label="OpenPortalKit Admin home">
            <span class="opk-brand-mark">OP</span>
            <span>
                <strong>OpenPortalKit</strong>
                <small>Admin</small>
            </span>
        </a>

        <nav class="opk-nav">
            <a class="opk-nav-link is-active" href="#dashboard"><span class="opk-nav-icon"></span>Dashboard</a>
            <a class="opk-nav-link" asp-page="/Content/Index"><span class="opk-nav-icon"></span>Content</a>
            <a class="opk-nav-link" href="#workflow"><span class="opk-nav-icon"></span>Workflow</a>
            <a class="opk-nav-link" href="#data"><span class="opk-nav-icon"></span>Data</a>
            <a class="opk-nav-link" href="#search"><span class="opk-nav-icon"></span>Search</a>
            <a class="opk-nav-link" href="#agent-access"><span class="opk-nav-icon"></span>Agent Access</a>
            <a class="opk-nav-link" href="#audit"><span class="opk-nav-icon"></span>Audit</a>
            <a class="opk-nav-link" href="#jobs"><span class="opk-nav-icon"></span>Jobs</a>
            <a class="opk-nav-link" href="#settings"><span class="opk-nav-icon"></span>Settings</a>
        </nav>

        <div class="opk-sidebar-status">
            <span class="opk-status-dot is-ok"></span>
            <span>Core boundary clean</span>
        </div>
    </aside>

    <div class="opk-workspace">
        <header class="opk-topbar">
            <div>
                <h1>Publishing Operations</h1>
                <p>Content, data, public outputs, workflow, and agent readiness.</p>
            </div>
            <div class="opk-topbar-actions">
                <a class="opk-button opk-button-secondary" href="/health">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 7.5 10.8 16.7 6.5 12.4" /></svg>
                    Health
                </a>
                <a class="opk-button opk-button-primary" href="/admin/system/modules">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
                    Modules
                </a>
            </div>
        </header>

        <section class="opk-metric-grid" id="dashboard-metrics" aria-label="Publishing health summary">
            <article class="opk-metric">
                <span class="opk-metric-label">Public readiness</span>
                <strong>84%</strong>
                <span class="opk-trend is-good">+6 this week</span>
            </article>
            <article class="opk-metric">
                <span class="opk-metric-label">Review queue</span>
                <strong>12</strong>
                <span class="opk-trend is-warn">4 waiting approval</span>
            </article>
            <article class="opk-metric">
                <span class="opk-metric-label">Data freshness</span>
                <strong>92%</strong>
                <span class="opk-trend is-good">All critical views current</span>
            </article>
            <article class="opk-metric">
                <span class="opk-metric-label">Job health</span>
                <strong>98%</strong>
                <span class="opk-trend is-good">1 retry pending</span>
            </article>
        </section>

        <section class="opk-alert-strip" id="dashboard-alerts" aria-label="Actionable dashboard alerts" hidden></section>

        <section class="opk-dashboard-grid" id="dashboard" aria-label="Dashboard cards">
            <div class="opk-panel opk-panel-wide">
                <div class="opk-panel-header">
                    <div>
                        <h2>Dashboard Signals</h2>
                        <p>Live module summaries from site operations, publishing, data, agent readiness, and system health.</p>
                    </div>
                </div>
                <div class="opk-dashboard-card-list" id="dashboard-card-list">
                    <div class="opk-empty-state">Loading dashboard signals...</div>
                </div>
            </div>
        </section>
    </div>
</section>

<script>
    (() => {
        const metricGrid = document.getElementById("dashboard-metrics");
        const alertStrip = document.getElementById("dashboard-alerts");
        const cardList = document.getElementById("dashboard-card-list");
        const areaNames = {
            0: "Site operations",
            1: "Content",
            2: "Data publishing",
            3: "Agent readiness",
            4: "System health"
        };

        const valueText = (metric) => {
            if (metric.unit === "percent") {
                return `${metric.value}%`;
            }

            if (metric.unit === "score") {
                return `${metric.value}`;
            }

            return `${metric.value}`;
        };

        const statusClass = (metric) => {
            if (metric.unit === "status") {
                return metric.value > 0 ? "is-approved" : "is-review";
            }

            if (metric.value > 0) {
                return "is-draft";
            }

            return "is-approved";
        };

        const detailText = (metric) => {
            const areaName = areaNames[metric.area] || "Dashboard";
            return `${areaName} - ${metric.unit}`;
        };

        const cardAnchor = (card) => {
            if (card.area === 1) {
                return "content";
            }

            if (card.area === 2) {
                return "data";
            }

            if (card.area === 3) {
                return "agent-access";
            }

            if (card.code === "system.background") {
                return "jobs";
            }

            if (card.area === 4) {
                return "settings";
            }

            return "";
        };

        const renderMetrics = (cards) => {
            const metrics = cards
                .flatMap((card) => card.metrics || [])
                .slice(0, 4);

            if (metrics.length === 0) {
                return;
            }

            metricGrid.replaceChildren(...metrics.map((metric) => {
                const article = document.createElement("article");
                article.className = "opk-metric";

                const label = document.createElement("span");
                label.className = "opk-metric-label";
                label.textContent = metric.label;

                const value = document.createElement("strong");
                value.textContent = valueText(metric);

                const detail = document.createElement("span");
                detail.className = metric.value > 0 ? "opk-trend is-good" : "opk-trend";
                detail.textContent = detailText(metric);

                article.append(label, value, detail);
                return article;
            }));
        };

        const renderCards = (cards) => {
            if (!cards.length) {
                const empty = document.createElement("div");
                empty.className = "opk-empty-state";
                empty.textContent = "No dashboard signals are available yet.";
                cardList.replaceChildren(empty);
                return;
            }

            const usedAnchors = new Set();
            cardList.replaceChildren(...cards.map((card) => {
                const section = document.createElement("section");
                section.className = "opk-dashboard-card";
                const anchor = cardAnchor(card);
                if (anchor && !usedAnchors.has(anchor)) {
                    section.id = anchor;
                    usedAnchors.add(anchor);
                }

                const header = document.createElement("div");
                header.className = "opk-dashboard-card-header";

                const titleGroup = document.createElement("div");
                const title = document.createElement("h3");
                title.textContent = card.title;
                const subtitle = document.createElement("p");
                subtitle.textContent = areaNames[card.area] || "Dashboard";
                titleGroup.append(title, subtitle);

                const badge = document.createElement("span");
                badge.className = card.alerts && card.alerts.length > 0 ? "opk-chip is-review" : "opk-chip is-approved";
                badge.textContent = `${card.alerts ? card.alerts.length : 0} alerts`;
                header.append(titleGroup, badge);

                const metrics = document.createElement("div");
                metrics.className = "opk-dashboard-metrics";
                metrics.append(...(card.metrics || []).map((metric) => {
                    const row = document.createElement("div");
                    row.className = "opk-data-row";

                    const label = document.createElement("span");
                    label.textContent = metric.description ? `${metric.label} - ${metric.description}` : metric.label;

                    const value = document.createElement("strong");
                    value.className = metric.unit === "status" ? `opk-chip ${statusClass(metric)}` : "";
                    value.textContent = valueText(metric);

                    row.append(label, value);
                    return row;
                }));

                section.append(header, metrics);
                return section;
            }));
        };

        const renderAlerts = (cards) => {
            const alerts = cards
                .flatMap((card) => card.alerts || [])
                .filter((alert) => alert.isActionable)
                .slice(0, 3);

            if (alerts.length === 0) {
                alertStrip.hidden = true;
                return;
            }

            alertStrip.hidden = false;
            alertStrip.replaceChildren(...alerts.map((alert) => {
                const link = document.createElement("a");
                link.className = alert.level >= 2 ? "opk-alert-link is-critical" : "opk-alert-link";
                link.href = alert.actionHref;
                link.textContent = alert.message;
                return link;
            }));
        };

        fetch("/admin/dashboard/summary")
            .then((response) => response.ok ? response.json() : null)
            .then((summary) => {
                if (!summary || !Array.isArray(summary.cards)) {
                    return;
                }

                renderMetrics(summary.cards);
                renderCards(summary.cards);
                renderAlerts(summary.cards);
            })
            .catch(() => {
                alertStrip.hidden = true;
                cardList.replaceChildren();
                const empty = document.createElement("div");
                empty.className = "opk-empty-state";
                empty.textContent = "Dashboard signals could not be loaded.";
                cardList.append(empty);
            });
    })();
</script>
