{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "OpenPortalKit": {
    "Persistence": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      }
    },
    "AgentAccess": {
      "PostgreSQL": {
        "Enabled": false,
        "ProviderInvariantName": "Npgsql",
        "ConnectionStringName": "Default"
      },
      "OutputGeneration": {
        "PublicBaseUrl": "http://localhost:5051",
        "SiteId": null,
        "AuthorDisplayName": "OpenPortalKit Editorial"
      }
    },
    "Jobs": {
      "Outbox": {
        "BatchSize": 20,
        "PollIntervalSeconds": 5,
        "ShutdownTimeoutSeconds": 30
      }
    }
  }
}
